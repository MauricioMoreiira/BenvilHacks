{
  "Frontend": {
    "BaseUrl": "http://localhost:5173"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Checkout": "Debug",
      "BenvilHacks.Api.PendingOrderStore": "Debug",
      "BenvilHacks.Api.MercadoPagoClient": "Information"
    }
  },
  "MercadoPago": {
    "PixHttp500MaxAttempts": 3,
    "PixHttp500RetryDelayMs": 500,
    "PixSandboxMode": "production_real_account",
    "RejectTestMercadoPagoCredentials": true,
    "PixPaymentDescription": "Produto",
    "PixIncludeExternalReference": true,
    "PixPayerEmailMustEndWith": "",
    "PixPayerEmailBlocklist": ""
  }
}
